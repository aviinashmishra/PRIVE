# ── Polygon Amoy testnet deployment ──────────────────────────────────────────
# Copy to .env (gitignored), fill in, then:  npm run preflight && npm run deploy:amoy

# RPC endpoint. Public default works; an Alchemy/Infura Amoy URL is more reliable.
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Private key of a FRESH, THROWAWAY wallet funded with test POL from
# https://faucet.polygon.technology (network: Amoy). NEVER use a real-funds key.
DEPLOYER_PRIVATE_KEY=

# Optional: for source verification on Polygonscan (npx hardhat verify)
POLYGONSCAN_API_KEY=

