# keep the build context small — only apps/buyer-web sources are needed
**/node_modules
**/.next
.git

# secrets never enter the image (templates are fine)
.env
**/.env
**/.env.*
!**/.env.example

# contracts: only sources + config are needed (the contracts stage compiles them)
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
contracts/deployments/
contracts/test/

# not needed to build the web app
docs/
api/
**/tsconfig.tsbuildinfo
Dockerfile
docker-compose.yml
render.yaml
