# Prive Exchange — Docker Compose configuration.
# Copy to .env next to docker-compose.yml. Every value has a dev-safe default;
# set real values before any non-local deployment.

# Postgres superuser password for the compose `db` service.
POSTGRES_PASSWORD=prive_dev_password

# HMAC secret for session JWTs. Generate one:  openssl rand -hex 32
AUTH_SECRET=

# Host port the web app is published on (change if 3000 is taken by another app).
WEB_PORT=3000

# Public origin of the app (used in emailed links) — keep in sync with WEB_PORT.
APP_URL=http://localhost:3000

# Passwords for the seeded demo users (blank = documented dev defaults).
SEED_ADMIN_PASSWORD=Avin@shm01
SEED_TRADER_PASSWORD=Avin@shm01
SEED_SELLER_PASSWORD=Avin@shm01

# Optional: JSON-RPC endpoint for the on-chain layer (e.g. http://host.docker.internal:8545).
CHAIN_RPC_URL=
