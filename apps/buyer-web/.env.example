# ── Database ─────────────────────────────────────────────────────────────────
# Either a Neon serverless URL (HTTP driver is picked automatically for *.neon.tech)
# or any plain Postgres URL (node-postgres driver), e.g. the Docker Compose db:
#   postgres://prive:prive_dev_password@localhost:5432/prive
# Without this set, the app still runs — API routes and auth fall back to an
# in-memory store (demo users only, state resets on restart).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for session JWTs — REQUIRED in production. Generate:
#   openssl rand -hex 32
AUTH_SECRET=

# Public origin used in emailed links (password reset).
APP_URL=http://localhost:3000

# Mandatory OTP email verification on signup/login. Off by default while the
# deployment has no reliable SMTP; set true to restore it (docs/05 §2).
REQUIRE_EMAIL_VERIFICATION=false

# Passwords for the seeded demo users (db/seed.mjs). Blank = dev defaults
# (Admin!Prive2026 / Trader!Prive2026 / Seller!Prive2026).
SEED_ADMIN_PASSWORD=
SEED_TRADER_PASSWORD=
SEED_SELLER_PASSWORD=
# Owner admin (avimishra8354@gmail.com — upserted with role admin on every seed).
SEED_OWNER_PASSWORD=

# ── Email (verification codes & password resets) ─────────────────────────────
# Any SMTP provider; the Docker stack points these at Mailpit. If SMTP_HOST is
# unset, emails are printed to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Prive Exchange <no-reply@prive.exchange>"

# ── Chain (optional) ─────────────────────────────────────────────────────────
# JSON-RPC endpoint + settler key for the on-chain panel (see contracts/).
# In the Docker image, leaving CHAIN_RPC_URL empty boots an EMBEDDED anvil node
# and deploys the contracts at startup (disable with CHAIN_EMBEDDED=false).
# Path of the runtime deployment descriptor (defaults are fine everywhere).
CHAIN_RPC_URL=
CHAIN_ADMIN_KEY=
CHAIN_DEPLOYMENT_FILE=
